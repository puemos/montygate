---
import "../styles/global.css";
import { Code } from "astro:components";
import ConversationFlow from "../components/ConversationFlow.astro";
import MetricsRow from "../components/MetricsRow.astro";
import { normalizeBenchmarkData } from "../lib/benchmark";

import data from "../../../packages/node/benchmark-results.json";

const { scenarios, tableRows } = normalizeBenchmarkData(data);

const pythonSnippet = `order = tool('lookup_order', order_id='ORD-7291')
customer = tool('get_customer', customer_id=order['customer_id'])
eligibility = tool('check_refund_eligibility',
    order_id='ORD-7291', customer_tier=customer['tier'])
refund = tool('process_refund',
    amount=order['total'] * (eligibility['max_refund_pct'] / 100),
    order_id='ORD-7291', policy_id=eligibility['policy_id'])
tool('send_notification', channel='email',
    recipient=customer['email'],
    subject='Refund Processed',
    body='Refund ' + refund['refund_id'] + ' confirmed.')`;

const tsSnippet = `import { Montygate } from "montygate";

const gate = new Montygate({ tools: myTools, handlers });

const response = await client.messages.create({
  tools: gate.anthropic(),
  messages,
});`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Montygate</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- A. Header -->
    <header>
      <h1>Montygate</h1>
      <p class="tagline">N tool calls. One round-trip.</p>
    </header>

    <!-- B. The Problem -->
    <section class="problem">
      <h2>Every tool call is a round-trip.</h2>
      <p>
        LLM asks for tool A, waits for the result, uses it to ask for tool B,
        waits again. Wire up five tools and a simple workflow becomes five
        sequential calls &mdash; each one re-sending the entire conversation,
        burning tokens and latency.
      </p>
    </section>

    <!-- C. Conversation Comparison -->
    <section class="hero">
      <h2>What this looks like</h2>

      <div class="scenario-chips" role="tablist">
        {scenarios.map((s, i) => (
          <button
            class={`scenario-chip ${i === 0 ? "active" : ""}`}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            data-tab={i}
          >
            {s.name}
          </button>
        ))}
      </div>

      {scenarios.map((s, i) => (
        <div class={`scenario-panel ${i === 0 ? "active" : ""}`} data-panel={i} role="tabpanel">
          <div class="flow-wrapper">
            <div class="comparison-grid">
              <ConversationFlow
                title="Traditional"
                conversation={s.traditional?.conversation ?? []}
              />
              <ConversationFlow
                title="Montygate"
                conversation={s.montygate?.conversation ?? []}
              />
            </div>
            <div class="flow-fade"></div>
            <button class="flow-expand-btn">Show more</button>
          </div>
          {s.montygate?.savingsVsTraditional && (
            <MetricsRow
              metrics={[
                {
                  value: `${s.montygate.savingsVsTraditional.round_trips_pct}%`,
                  label: "fewer round-trips",
                },
                {
                  value: `${s.montygate.savingsVsTraditional.input_tokens_pct}%`,
                  label: "fewer tokens",
                },
                {
                  value: `${s.montygate.savingsVsTraditional.cost_pct}%`,
                  label: "lower agent cost",
                },
                {
                  value: `${s.montygate.eval.passed}/${s.montygate.eval.total}`,
                  label: "eval score",
                },
              ]}
            />
          )}
        </div>
      ))}
    </section>

    <!-- E. How It Works -->
    <section>
      <h2>One script, five tools</h2>
      <Code code={pythonSnippet} lang="python" theme="github-light" />
      <p class="code-caption">
        The LLM writes this. Montygate runs it in a sandbox.
      </p>
    </section>

    <!-- F. All Benchmarks -->
    <section>
      <h2>Across {data.scenarios.length} scenarios</h2>
      <table class="benchmark-table">
        <thead>
          <tr>
            <th>Scenario</th>
            <th>Tools</th>
            <th>Round-trips</th>
            <th>Tokens</th>
            <th>Agent Cost</th>
            <th>Eval</th>
          </tr>
        </thead>
        <tbody>
          {tableRows.map((row) => (
            <tr>
              <td class="scenario-name">{row.scenario}</td>
              <td>{row.tools}</td>
              <td class={row.savings.round_trips_pct >= 0 ? "positive" : "negative"}>
                {row.savings.round_trips_pct >= 0 ? "-" : "+"}{Math.abs(row.savings.round_trips_pct)}%
              </td>
              <td class={row.savings.input_tokens_pct >= 0 ? "positive" : "negative"}>
                {row.savings.input_tokens_pct >= 0 ? "-" : "+"}{Math.abs(row.savings.input_tokens_pct)}%
              </td>
              <td class={row.savings.cost_pct >= 0 ? "positive" : "negative"}>
                {row.savings.cost_pct >= 0 ? "-" : "+"}{Math.abs(row.savings.cost_pct)}%
              </td>
              <td>
                <span class={`eval-score ${row.eval.score === 1 ? "eval-pass" : row.eval.score >= 0.5 ? "eval-partial" : "eval-fail"}`}>
                  {row.eval.passed}/{row.eval.total}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="footnote">
        Benchmarked with Claude Haiku 4.5. Cost figures are agent-run cost only and exclude LLM-as-judge usage.
      </p>
    </section>

    <!-- G. Get Started -->
    <section class="get-started">
      <h2>Get started</h2>
      <Code code="npm install montygate" lang="bash" theme="github-light" />
      <Code code={tsSnippet} lang="typescript" theme="github-light" />
      <p>
        <a href="https://github.com/puemos/montygate">View on GitHub</a>
      </p>
    </section>

    <!-- H. Footer -->
    <footer>
      <span>MIT / Apache-2.0</span>
      <a href="https://github.com/puemos/montygate">GitHub</a>
    </footer>

    <script>
      // Expand/collapse flow items — auto-expand wrapper if collapsed
      document.querySelectorAll('.flow-item.expandable .flow-header').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.flow-item')!;
          const isOpen = item.classList.toggle('open');
          btn.setAttribute('aria-expanded', String(isOpen));

          if (isOpen) {
            const wrapper = item.closest('.flow-wrapper');
            if (wrapper && !wrapper.classList.contains('expanded')) {
              wrapper.classList.add('expanded');
              const expandBtn = wrapper.querySelector('.flow-expand-btn') as HTMLElement;
              if (expandBtn) expandBtn.textContent = 'Show less';
            }
          }
        });
      });

      // Flow wrapper: detect if content fits, handle expand/collapse
      function checkFlowFit(wrapper: Element) {
        const grid = wrapper.querySelector('.comparison-grid') as HTMLElement;
        if (!grid) return;
        // Only check visible wrappers (hidden ones report 0 scrollHeight)
        if (grid.scrollHeight <= 360 && grid.scrollHeight > 0) {
          wrapper.classList.add('fits');
        } else {
          wrapper.classList.remove('fits');
        }
      }

      document.querySelectorAll('.flow-wrapper').forEach(wrapper => {
        const btn = wrapper.querySelector('.flow-expand-btn') as HTMLElement;
        if (!btn) return;
        checkFlowFit(wrapper);
        btn.addEventListener('click', () => {
          const expanded = wrapper.classList.toggle('expanded');
          btn.textContent = expanded ? 'Show less' : 'Show more';
        });
      });

      // Scenario chip switching
      document.querySelectorAll('.scenario-chip').forEach(chip => {
        chip.addEventListener('click', () => {
          const idx = (chip as HTMLElement).dataset.tab;
          document.querySelectorAll('.scenario-chip').forEach(t => {
            const active = (t as HTMLElement).dataset.tab === idx;
            t.classList.toggle('active', active);
            t.setAttribute('aria-selected', String(active));
          });
          document.querySelectorAll('.scenario-panel').forEach(p => {
            (p as HTMLElement).classList.toggle('active', (p as HTMLElement).dataset.panel === idx);
          });
          // Re-check fit for newly visible panel
          const activePanel = document.querySelector(`.scenario-panel[data-panel="${idx}"]`);
          const wrapper = activePanel?.querySelector('.flow-wrapper');
          if (wrapper) checkFlowFit(wrapper);
        });
      });
    </script>
  </body>
</html>
